{
  "open network settings": "start ms-settings:network",
  "open wifi settings": "start ms-settings:network-wifi",
  "open bluetooth settings": "start ms-settings:bluetooth",
  "open night light settings": "start ms-settings:nightlight",
  "open display settings": "start ms-settings:display",
  "open power options": "start ms-settings:powersleep",

  "bluetooth on": "powershell.exe -Command \"$bt = Get-PnpDevice -Class Bluetooth | Where-Object {$_.Status -eq 'OK'}; $bt | Enable-PnpDevice -Confirm:$false\"",
  "bluetooth off": "powershell.exe -Command \"$bt = Get-PnpDevice -Class Bluetooth | Where-Object {$_.Status -eq 'OK'}; $bt | Disable-PnpDevice -Confirm:$false\"",

  "wifi on": "powershell.exe -Command \"netsh interface set interface 'Wi-Fi' enabled\"",
  "wifi off": "powershell.exe -Command \"netsh interface set interface 'Wi-Fi' disabled\"",
  "hotspot on": "powershell.exe -Command \"netsh wlan start hostednetwork\"",
  "hotspot off": "powershell.exe -Command \"netsh wlan stop hostednetwork\"",

  "night light on": "powershell.exe -Command \"# Night light ON placeholder\"",
  "night light off": "powershell.exe -Command \"# Night light OFF placeholder\"",
  "wake screen": "python -c \"import ctypes; ctypes.windll.kernel32.SetThreadExecutionState(0x80000002)\"",

  "sleep": "rundll32.exe powrprof.dll,SetSuspendState 0,1,0",
  "shutdown": "shutdown /s /t 0",
  "restart": "shutdown /r /t 0",
  "log off": "shutdown /l /t 0",
  "lock": "rundll32.exe user32.dll,LockWorkStation",

  "volume up": "powershell.exe -Command \"$ws = New-Object -ComObject WScript.Shell; $ws.SendKeys([char]175)\"",
  "volume down": "powershell.exe -Command \"$ws = New-Object -ComObject WScript.Shell; $ws.SendKeys([char]174)\"",
  "mute": "powershell.exe -Command \"$ws = New-Object -ComObject WScript.Shell; $ws.SendKeys([char]173)\""
}